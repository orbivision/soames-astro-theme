---
// Documentation landing (/docs/). Same hero + two-column shell as a doc page:
// the left column is an index of top-level sections (each linking out, with its
// child articles listed beneath); the right column is the full docs nav. If
// weDocs isn't installed getDocs() returns [] and we show a friendly empty state.
import Base from "@theme/layouts/Base.astro";
import HeroHeader from "@theme/components/HeroHeader";
import DocsSidebar from "@theme/components/DocsSidebar";
import { getDocs, buildDocTree } from "../../lib/wp";

const docs = await getDocs();
const tree = buildDocTree(docs);
---
<Base pageTitle="Documentation" description="Documentation and guides.">
  <HeroHeader title="Documentation" subhead="" backgroundImage={null} overlayOpacity={0.6} />
  <section>
    <div class="media-container-row">
      <div class="col-12 col-lg-8">
        <section id="soames-gatsby-content-container" class="soames-gatsby-blog-content">
          <article class="blog-post">
            {tree.length === 0 ? (
              <p>Documentation is coming soon.</p>
            ) : (
              <div class="soames-docs-index">
                {tree.map((section) => (
                  <section class="soames-docs-index-section">
                    <h2><a href={section.uri} set:html={section.title} /></h2>
                    {section.children.length > 0 && (
                      <ul>
                        {section.children.map((child) => (
                          <li><a href={child.uri} set:html={child.title} /></li>
                        ))}
                      </ul>
                    )}
                  </section>
                ))}
              </div>
            )}
          </article>
        </section>
      </div>
      <div class="col-12 col-lg-4">
        <section id="soames-gatsby-sidebar-container" class="soames-gatsby-sidebar">
          <DocsSidebar tree={tree} currentId={0} />
        </section>
      </div>
    </div>
  </section>
</Base>
