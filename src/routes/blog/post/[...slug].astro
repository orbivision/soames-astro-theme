---
// Single blog post + featured image (parity with blog-post template).
import { Image } from "astro:assets";
import Base from "@theme/layouts/Base.astro";
import Shortcodes from "@theme/components/shortcodes/Shortcodes";
import { getPosts } from "../../../lib/wp";

export async function getStaticPaths() {
  const posts = await getPosts();
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const img = post.featuredImage;
---
<Base pageTitle={post.title}>
  <article class="soames-post">
    <h1>{post.title}</h1>
    <p><small>{new Date(post.date).toLocaleDateString()}</small></p>
    {img && img.width && img.height && (
      <Image
        src={img.sourceUrl}
        alt={img.altText}
        width={img.width}
        height={img.height}
        widths={[400, 800, 1200]}
        sizes="(max-width: 800px) 100vw, 800px"
      />
    )}
    <Shortcodes html={post.content} />
  </article>
</Base>
